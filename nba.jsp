<!DOCTYPE html>
<html>
    <head>
        <title>LCM Calculator</title>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
    </head>
    <body>
        <form action="bean" method="get">
            <table border="0">
                <tbody>
                    <tr>
                        <td>Enter integer number 1:</td>
                        <td><input type="text" name="num1" /></td>
                    </tr>
                    <tr>
                        <td>Enter integer number 2:</td>
                        <td><input type="text" name="num2" /></td>
                    </tr>
                    <tr>
                        <td>Enter integer number 3:</td>
                        <td><input type="text" name="num3" /></td>
                    </tr>
                    <tr>                        
                        <td>
                            <input type="submit" value="EXECUTE LCM" />
                        </td>
                    </tr>
                </tbody>
            </table>
        </form>
    </body>
</html>